# Optional — bridge works without .env (uses embedded defaults)
# Uncomment and fill in to override the embedded Supabase credentials.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Set to any value to open localhost:3000 instead of the production URL on startup.
# JARVIS_LOCAL_DEV=1
